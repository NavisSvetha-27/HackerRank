import java.io.*;
import java.util.*;
import java.text.*;
import java.math.*;
import java.util.regex.*;

public class Solution{
    public static void main(String[] args){
        
        Scanner in = new Scanner(System.in);
        int testCases = Integer.parseInt(in.nextLine());
        while(testCases>0){
            String line = in.nextLine();
            
              // 1. Regex: <([^<>]+)> matches start tag and captures name in Group 1
            // 2. ([^<>]+) matches the content and captures in Group 2
            // 3. </\1> uses a backreference to match the exact same closing tag
            String regex = "<([^<>]+)>([^<>]+)</\\1>";
            Pattern p = Pattern.compile(regex);
            Matcher m = p.matcher(line);
            
            boolean found = false;
            while (m.find()) {
                // group(2) contains the text between the tags
                System.out.println(m.group(2));
                found = true;
            }
            
            if (!found) {
                System.out.println("None");
            }
            
            testCases--;
        }
        in.close();
    }
}



